  "servers": [
    {
      "id": "threatbook_mcp",
      "name": "ThreatBook MCP",
      "description": "ThreatBook threat intelligence MCP service for IOC lookups, threat analysis, and security investigation workflows.",
      "category": "threat_intelligence",
      "github": "",
      "language": "remote",
      "license": "Proprietary",
      "stars": 0,
      "transport": "remote",
      "remote": {
        "url": "https://mcp.threatbook.cn/mcp",
        "transport": "auto",
        "auth": {
          "type": "apikey",
          "location": "query",
          "param_name": "apikey",
          "value": "{secret:threatbook_mcp_key}"
        }
      },
      "env_vars": {
        "THREATBOOK_MCP_KEY": {
          "required": true,
          "description": "ThreatBook MCP API Key",
          "secret": true
        }
      },
      "tags": [
        "threat-intelligence",
        "ioc",
        "analysis"
      ],
      "official": true,
      "description_cn": "微步威胁情报 MCP 服务，提供 IOC 查询、威胁情报研判与安全分析能力。"
    },
