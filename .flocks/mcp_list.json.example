    {
      "id": "panther",
      "name": "Panther SIEM",
      "description": "Panther SIEM platform integration for writing detection rules with natural language, querying logs, and managing alerts.",
      "category": "siem",
      "github": "panther-labs/mcp-panther",
      "language": "python",
      "license": "AGPL-3.0",
      "stars": 30,
      "transport": "local",
      "install": {
        "pip": "mcp-panther",
        "local_command": [
          "python",
          "-m",
          "mcp_panther"
        ]
      },
      "env_vars": {
        "PANTHER_API_TOKEN": {
          "required": true,
          "description": "Panther API令牌",
          "secret": true
        },
        "PANTHER_API_HOST": {
          "required": true,
          "description": "Panther API主机"
        }
      },
      "tags": [
        "siem",
        "detection",
        "log-analysis",
        "alerts"
      ],
      "description_cn": "Panther SIEM 平台集成，支持用自然语言编写检测规则、查询日志并管理告警。"
    },
